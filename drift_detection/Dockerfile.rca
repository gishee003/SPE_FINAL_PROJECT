FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY drift_detection/rca_xai.py /app/rca_xai.py
COPY drift_detection/rca_service.py /app/rca_service.py
COPY drift_detection/dashboard.html /app/dashboard.html

EXPOSE 5004

CMD ["python", "rca_service.py"]
